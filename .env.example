# Application
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=true
REQUIRE_HTTPS=false

# Database
DATABASE_URL=postgresql+asyncpg://portal:portal@localhost:5432/portal

# Redis
REDIS_URL=redis://localhost:6379/1

# Session cookie signing
SECRET_KEY=dev-secret-change-me-in-production
SESSION_TTL_SECONDS=86400

# Gateway integration
# NOTE: http://localhost is for local development only — production MUST use https://
GATEWAY_ADMIN_URL=http://localhost:8000
GATEWAY_SERVICE_JWT=

# HMAC shared secret between gateway and portal for the validate endpoint.
# Must match PORTAL_SHARED_SECRET in the gateway's env.
GATEWAY_PORTAL_SHARED_SECRET=dev-shared-secret-change-me-in-production

# HMAC timestamp acceptance window in seconds
HMAC_TIMESTAMP_WINDOW_SECONDS=30
